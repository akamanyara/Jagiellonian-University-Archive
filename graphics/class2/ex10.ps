%!PS-Adobe-3.0

% Utwórz "zakreskowany tekst"

/Times-Roman findfont 90 scalefont setfont

newpath
100 100 moveto
(napisy) true charpath clip

gsave
1 0 0 setrgbcolor
100 105 moveto
500 100 lineto
stroke
grestore

gsave
0 1 0 setrgbcolor
100 110 moveto
500 100 lineto
stroke 
grestore

gsave
0 0 1 setrgbcolor
100 115 moveto
500 100 lineto
stroke 
grestore

gsave
0 1 0 setrgbcolor
100 120 moveto
500 100 lineto
stroke 
grestore

gsave
1 0 0 setrgbcolor
100 125 moveto
500 100 lineto
stroke 
grestore

stroke 
showpage


