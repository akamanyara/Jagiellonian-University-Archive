%!PS-Adobe-3.0
%%Title: Projekt - plakat: Cup Of Coffee

% background
0.96 0.9 0.8 setrgbcolor
clippath fill % zalewanie kolorem dostepnego obszaru

% ramka
0.3 0.15 0.05 setrgbcolor
5 setlinewidth
20 20 555 802 rectstroke % narysowanie rect o parametrach wyzej

% procedura do tworzenia ziarna
/ziarno {
    6 dict begin
        /kat exch def /skala exch def
        /y exch def /x exch def
        
        gsave
            % transformacje
            x y translate
            kat rotate
            skala skala scale
            
            % ksztalt ziarna (owal)
            0.4 0.2 0.05 setrgbcolor
            gsave
                1 0.65 scale
                newpath 0 0 20 0 360 arc fill
            grestore
            
            % pekniecie w ziarnie
            0.15 0.05 0 setrgbcolor
            2 setlinewidth
            newpath -15 0 moveto -5 8 5 -8 15 0 curveto stroke
        grestore
    end
} def

% tablica ziaren (x, y, skala, kat)
/baza_ziaren [
    80 750 1.2 45     150 800 0.8 -30    450 780 1.5 60
    500 700 1.0 -15   60 150 1.3 120     120 80 0.9 -45
    480 120 1.1 200   400 60 1.4 -80
] def

% rysowanie ziaren
0 4 baza_ziaren length 1 sub {
    /i exch def
    /zx baza_ziaren i get def
    /zy baza_ziaren i 1 add get def
    /zs baza_ziaren i 2 add get def
    /za baza_ziaren i 3 add get def
    
    zx zy zs za ziarno
} for

% rysunek - filizanka
gsave
    300 350 translate % translate na srodek filizanki
    
    % talerzyk (elipsa)
    0.3 0.15 0.05 setrgbcolor
    gsave 1 0.2 scale newpath 0 -300 180 0 360 arc fill grestore
    0.8 0.7 0.6 setrgbcolor
    gsave 1 0.2 scale newpath 0 -300 140 0 360 arc fill grestore

    % ucho
    1 1 1 setrgbcolor
    30 setlinewidth
    newpath 120 20 60 -90 90 arc stroke

    % dol filizanki
    1 1 1 setrgbcolor
    newpath -120 80 moveto -80 -80 lineto 80 -80 lineto 120 80 lineto closepath fill
    
    % pasek ozdobny
    0.8 0.2 0.2 setrgbcolor
    newpath -95 -20 moveto 95 -20 lineto stroke

    % kawa w srodku
    0.2 0.1 0.05 setrgbcolor
    gsave 1 0.25 scale newpath 0 320 120 0 360 arc fill grestore

grestore

% tekst - tytul i podtytul
/Times-Bold findfont 55 scalefont setfont
0.3 0.15 0.05 setrgbcolor
85 620 moveto (CUP OF COFFEE) show

/Times-Oblique findfont 25 scalefont setfont
0.6 0.3 0.1 setrgbcolor
140 200 moveto (Najlepsza kawiarnia w miescie) show

showpage